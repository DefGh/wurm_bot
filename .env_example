# Copy this file to .env and set your local Wurm event log directory.
# macOS Steam example:
WURM_LOGS_DIR="/Users/your-user/Library/Application Support/Steam/steamapps/common/Wurm Online/gamedata/players/YourPlayer/logs"

# Optional: used only when WURM_LOGS_DIR is not set.
WURM_PLAYER="YourPlayer"

# Optional fallback if the Wurm window cannot be auto-detected.
# Format: x,y,width,height
# WURM_WINDOW_REGION="0,25,1440,900"

# Optional: text used to find the Wurm window by process or window title.
WURM_WINDOW_MATCH="Wurm Online"
WURM_WINDOW_EXCLUDE="wurm_bot,visual studio code,code,codex"

# Optional: seconds to wait for macOS window detection.
WURM_WINDOW_DETECT_TIMEOUT="3"

# Optional: macOS window screenshot backend.
# window is the default because it captures by macOS window id, not by display coordinates.
WURM_MAC_SCREENSHOT_BACKEND="window"

# Optional: use rectangle-based capture instead.
# WURM_MAC_SCREENSHOT_BACKEND="mss"
# WURM_MAC_SCREENSHOT_BACKEND="pyautogui"

# Optional: allow full-screen capture if window detection fails.
# WURM_ALLOW_FULL_SCREEN_FALLBACK="1"

# Optional: save every raw screenshot taken by the bot. Disabled by default.
# WURM_SAVE_RAW_SCREENSHOTS="1"

# Optional: local Wurm-window HUD pixels used to guard Improve actions.
# By default the bot finds these lines from the player nameplate template.
# Fixed coordinates below are still used as a fallback when the nameplate is not found.
# Coordinates are x1,x2,y in the captured Wurm screenshot, not global screen coordinates.
WURM_STAMINA_LINE="32,229,82"
WURM_WATER_LINE="32,106,92"
WURM_FOOD_LINE="138,239,92"
WURM_STAMINA_READY_RGB="95,136,34"
WURM_WATER_MIN_RGB="70,114,165"
WURM_FOOD_EMPTY_RGB="53,46,37"
WURM_VITALS_COLOR_TOLERANCE="35"
WURM_VITALS_SAMPLE_COUNT="20"
WURM_STAMINA_MIN_FILLED="100"
WURM_WATER_MIN_FILLED="70"
WURM_FOOD_MIN_FILLED="70"
WURM_VITALS_POLL_SECONDS="1.0"
WURM_VITALS_NAMEPLATE_TEMPLATE="wurm_bot/assets/vitals_templates/nameplate_defgh.png"
WURM_VITALS_NAMEPLATE_MATCH_THRESHOLD="0.90"
WURM_VITALS_NAMEPLATE_SEARCH_WIDTH="520"
WURM_VITALS_NAMEPLATE_SEARCH_HEIGHT="220"

# Optional live vitals overlay window.
# The live overlay draws two-color squares around sampled vitals pixels.
# Green = sampled pixel counts as OK/filled; red = it does not.
WURM_VITALS_OVERLAY_MARKER_SIZE="7"
WURM_VITALS_OVERLAY_OFFSET_X="16"
WURM_VITALS_OVERLAY_OFFSET_Y="16"
WURM_VITALS_OVERLAY_TOPMOST="1"

# Optional: auto refill water when the vitals guard sees low water.
# Put your drink/water item in the toolbelt and bind its slot/action here.
# WURM_WATER_TOOLBELT_KEY="1"
# WURM_WATER_DRINK_KEY=""

# Optional smithing maintenance.
# The bot looks for visible forge/furnace/oven/smelter and visible Inventory windows.
WURM_SMITHING_HEAT_SECONDS="25"
WURM_SMITHING_FIRE_INTERVAL_SECONDS="300"
